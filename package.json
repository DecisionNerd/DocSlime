{
  "name": "docslime-docs",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "docmd dev",
    "build": "npm run check:markdown && docmd build && node scripts/check-rendered-line-breaks.mjs",
    "format:markdown": "prettier --write \"**/*.md\" && node scripts/format-markdown-comments.mjs",
    "check:markdown": "prettier --check \"**/*.md\" && node scripts/format-markdown-comments.mjs --check",
    "preview": "npx serve site"
  },
  "dependencies": {
    "@docmd/core": "^0.8.10"
  },
  "devDependencies": {
    "prettier": "3.6.2"
  }
}
