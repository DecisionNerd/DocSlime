{
  "title": "DocSlime",
  "url": "https://www.docslime.dev",
  "favicon": "/assets/favicon.svg",
  "src": "docs",
  "out": "site",
  "engine": "js",
  "layout": {
    "footer": {
      "style": "minimal",
      "content": "© 2026 DecisionNerd. DocSlime documentation.",
      "branding": true
    }
  },
  "theme": {
    "name": "default",
    "appearance": "system",
    "customCss": ["/assets/styles/docslime.css"],
    "codeHighlight": true
  },
  "minify": true,
  "autoTitleFromH1": true,
  "copyCode": true,
  "pageNavigation": true,
  "navigation": [
    { "title": "Overview", "path": "/", "icon": "zap" },
    { "title": "Lifecycle", "path": "/lifecycle/", "icon": "workflow" },
    { "title": "Product", "path": "/PRODUCT/", "icon": "target" },
    { "title": "Design", "path": "/DESIGN/", "icon": "palette" },
    { "title": "Strategy", "path": "/strategy/", "icon": "telescope" },
    { "title": "Experience", "path": "/experience/", "icon": "route" },
    { "title": "Requirements", "path": "/REQUIREMENTS/", "icon": "list-checks" },
    { "title": "Agent Skills", "path": "/skills/", "icon": "brain-circuit" },
    {
      "title": "Engineering",
      "icon": "wrench",
      "collapsible": false,
      "children": [
        { "title": "Engineering", "path": "/engineering/", "icon": "file-code" },
        { "title": "Architecture", "path": "/engineering/ARCHITECTURE/", "icon": "boxes" },
        { "title": "Testing", "path": "/engineering/TESTING/", "icon": "flask-conical" },
        { "title": "Publishing", "path": "/engineering/PUBLISHING/", "icon": "upload-cloud" },
        { "title": "Observability", "path": "/engineering/OBSERVABILITY/", "icon": "activity" },
        { "title": "ADRs", "path": "/engineering/adrs/", "icon": "scroll-text" }
      ]
    },
    { "title": "GitHub", "path": "https://github.com/DecisionNerd/DocSlime", "icon": "github", "external": true }
  ],
  "plugins": {
    "git": {
      "commitHistory": true,
      "maxCommits": 5
    },
    "seo": {
      "defaultDescription": "DocSlime is an opinionated CLI and agent-skill system for building living, agent-ready documentation inside a repo.",
      "openGraph": {
        "defaultImage": "/assets/images/docslime-hero.png"
      }
    },
    "okf": {
      "warnOnMissingType": false
    }
  }
}
