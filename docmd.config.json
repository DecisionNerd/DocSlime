{
  "title": "DocSlime",
  "url": "https://www.docslime.dev",
  "src": "docs",
  "out": "site",
  "engine": "js",
  "layout": {
    "spa": true,
    "header": {
      "enabled": true
    },
    "sidebar": {
      "collapsible": true,
      "defaultCollapsed": false
    },
    "optionsMenu": {
      "position": "sidebar-top",
      "components": {
        "search": true,
        "themeSwitch": true
      }
    },
    "footer": {
      "style": "minimal",
      "content": "© 2026 DecisionNerd. DocSlime documentation.",
      "branding": true
    }
  },
  "theme": {
    "name": "default",
    "appearance": "system",
    "codeHighlight": true
  },
  "minify": true,
  "autoTitleFromH1": true,
  "copyCode": true,
  "pageNavigation": true,
  "navigation": [
    { "title": "Overview", "path": "/", "icon": "zap" },
    { "title": "Product", "path": "/PRODUCT/", "icon": "target" },
    { "title": "Experiences", "path": "/1-EXPERIENCES/", "icon": "route" },
    { "title": "Requirements", "path": "/2-REQUIREMENTS/", "icon": "list-checks" },
    { "title": "Design", "path": "/DESIGN/", "icon": "palette" },
    { "title": "Architecture", "path": "/3-ARCHITECTURE/", "icon": "boxes" },
    { "title": "Testing", "path": "/4-TESTING/", "icon": "flask-conical" },
    { "title": "Agent Skills", "path": "/skills/", "icon": "brain-circuit" },
    {
      "title": "Engineering",
      "icon": "wrench",
      "collapsible": false,
      "children": [
        { "title": "Engineering", "path": "/3-ENGINEERING/", "icon": "file-code" },
        { "title": "ADRs", "path": "/3-ENGINEERING/ADRs/", "icon": "scroll-text" }
      ]
    },
    { "title": "GitHub", "path": "https://github.com/DecisionNerd/DocSlime", "icon": "github", "external": true }
  ],
  "plugins": {
    "git": {
      "commitHistory": true,
      "maxCommits": 5
    },
    "seo": {
      "defaultDescription": "DocSlime is an opinionated CLI and agent-skill system for building living, agent-ready documentation inside a repo."
    },
    "okf": {
      "warnOnMissingType": false
    }
  }
}
